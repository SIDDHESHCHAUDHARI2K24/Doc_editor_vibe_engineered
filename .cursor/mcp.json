{
  "mcpServers": {
    "figma": {
      "command": "npx",
      "args": ["-y", "figma-mcp"],
      "env": {
        "FIGMA_API_KEY": "${FIGMA_API_KEY}"
      }
    },
    "graphify": {
      "command": "./tools/graphify/.venv/Scripts/python.exe",
      "args": ["-m", "graphify.serve", "./graphify-out/graph.json"]
    }
  }
}
