# ============================================
# Collaborative Document Editor — Environment Variables
# Copy to .env and adjust for your local setup.
# ============================================

# --- App ---
APP_NAME=docs-editor
ENVIRONMENT=development
LOG_LEVEL=DEBUG
DEBUG=true
VERSION=0.1.0

# --- HTTP ---
CORS_ORIGINS=["http://localhost:5173"]
CSRF_SECRET_KEY=dev-csrf-secret-change-in-prod

# --- Postgres ---
POSTGRES_HOST_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=docs_editor
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/docs_editor

# --- Valkey ---
VALKEY_HOST_PORT=6379
VALKEY_URL=redis://localhost:6379/0
SESSION_TTL_SECONDS=604800

# --- MinIO (Object Storage) ---
MINIO_HOST_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_ADDRESSING_STYLE=path
S3_REGION=us-east-1
S3_BUCKET_DOCUMENTS=docs
S3_BUCKET_SNAPSHOTS=snapshots
S3_BUCKET_ATTACHMENTS=attachments

# --- Auth ---
BCRYPT_COST=10
SESSION_COOKIE_NAME=session_id
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax

# --- Rate Limiting ---
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_SECONDS=300
RATE_LIMIT_SHARING_MAX=20
RATE_LIMIT_SHARING_WINDOW_SECONDS=60
RATE_LIMIT_UPLOAD_MAX=10
RATE_LIMIT_UPLOAD_WINDOW_SECONDS=60

# --- WebSocket ---
WS_MAX_MESSAGE_BYTES=1048576

# --- Uploads ---
UPLOAD_MAX_TXT_MD_BYTES=1048576
UPLOAD_MAX_DOCX_BYTES=10485760
UPLOAD_MAX_ATTACHMENT_BYTES=26214400
